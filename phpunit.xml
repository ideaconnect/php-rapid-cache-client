<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" backupGlobals="false" bootstrap="vendor/autoload.php" xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.5/phpunit.xsd" colors="true" cacheDirectory=".phpunit.cache">
  <coverage>
    <report>
      <clover outputFile="report/coverage.xml"/>
      <html outputDirectory="report/" lowUpperBound="35" highLowerBound="80"/>
      <text outputFile="coverage.txt" showUncoveredFiles="true" showOnlySummary="false"/>
    </report>
  </coverage>
  <testsuite name="RedisCacheService TestSuite">
    <directory suffix="Test.php">./tests</directory>
  </testsuite>
  <logging/>
  <php>
    <env name="XDEBUG_MODE" value="coverage"/>
    <env name="REDIS_HOST" value="localhost"/>
    <env name="REDIS_PORT" value="6380"/>
  </php>
  <source>
    <include>
      <directory suffix=".php">src</directory>
    </include>
  </source>
</phpunit>
