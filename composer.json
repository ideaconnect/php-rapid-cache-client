{
    "name": "gryf-oss/rapid-cache-client",
    "description": "Caching service",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "IDCT Bartosz Pachołek",
            "email": "bartosz+github@idct.tech",
            "role": "Developer"
        },
        {
            "name": "Karol from Praetorian Technology",
            "email": "karol@praetorian.technology",
            "role": "Developer"
        },
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "ext-igbinary": "*",
        "ext-redis": "*"
    },
    "autoload": {
        "psr-4": {
            "GryfOSS\\Cache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GryfOSS\\Tests\\Cache\\": "tests/"
        }
    },
    "scripts": {
        "redis:start": "docker compose up -d valkey",
        "redis:stop": "docker compose down",
        "redis:wait": "sleep 10",
        "test:unit": [
            "@redis:start",
            "@redis:wait",
            "XDEBUG_MODE=coverage ./vendor/phpunit/phpunit/phpunit",
            "@redis:stop"
        ],
        "test:unit-no-coverage": [
            "@redis:start",
            "@redis:wait",
            "./vendor/phpunit/phpunit/phpunit --no-coverage",
            "@redis:stop"
        ],
        "test:functional": [
            "@redis:start",
            "@redis:wait",
            "./vendor/bin/behat",
            "@redis:stop"
        ],
        "test": [
            "composer install",
            "@test:unit",
            "@test:functional"
        ],
        "fix": "./vendor/friendsofphp/php-cs-fixer/php-cs-fixer fix --allow-risky=yes"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "php-mock/php-mock": "^2.3",
        "php-mock/php-mock-phpunit": "^2.6",
        "friendsofphp/php-cs-fixer": "^2.17",
        "behat/behat": "^3.8"
    }
}
