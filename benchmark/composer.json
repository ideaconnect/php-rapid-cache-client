{
    "name": "idct/rapid-cache-benchmark",
    "description": "Throughput benchmark for IDCT Rapid Cache's own operations (Core, Tagging, Counters)",
    "type": "project",
    "require": {
        "php": "^8.5",
        "ext-igbinary": "*",
        "ext-redis": "*",
        "ext-json": "*",
        "idct/php-rapid-cache-client": "*",
        "monolog/monolog": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "IDCT\\RapidCacheBenchmark\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../"
        }
    ],
    "scripts": {
        "benchmark": "php bin/benchmark.php"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "process-timeout": 0
    }
}
