{
    "name": "idct/rapid-cache-benchmark",
    "description": "Benchmark comparison between IDCT Rapid Cache and other Redis cache implementations",
    "type": "project",
    "require": {
        "php": "^8.5",
        "ext-igbinary": "*",
        "ext-redis": "*",
        "ext-json": "*",
        "idct/php-rapid-cache-client": "*",
        "symfony/cache": "^8.0",
        "symfony/console": "^8.0",
        "monolog/monolog": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "IDCT\\RapidCacheBenchmark\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../"
        }
    ],
    "scripts": {
        "benchmark": "php bin/benchmark.php",
        "benchmark:all": [
            "php bin/benchmark.php --adapter=rapid-cache",
            "php bin/benchmark.php --adapter=symfony-igbinary",
            "php bin/benchmark.php --adapter=symfony-json"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "process-timeout": 0
    }
}
